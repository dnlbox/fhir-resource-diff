---
/**
 * Custom Hero component for the fhir-resource-diff homepage.
 * Renders the splash layout with feature grid below the hero text.
 * Starlight passes the hero frontmatter data as a prop automatically
 * when this component overrides the built-in Hero slot.
 */

import type { Props } from "@astrojs/starlight/props";
import Default from "@astrojs/starlight/components/Hero.astro";
---

<Default {...Astro.props}>
  <slot />
</Default>
